{% extends 'base.html.twig' %}

{% block title %}Nos Solutions | ShoppingFree{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">L'expérience ShoppingFree</h1>
        <p class="lead">Plus qu'une boutique, un service d'excellence pour vos produits high-tech.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm border-0 rounded-4 text-center">
                <i class="bi bi-shield-lock fs-1 text-primary mb-3"></i>
                <h3 class="h5 fw-bold">Sécurité Garantie</h3>
                <p class="text-muted">Vos transactions sont protégées par le cryptage AES-256 de Stripe. Achetez en toute sérénité.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm border-0 rounded-4 text-center">
                <i class="bi bi-truck fs-1 text-primary mb-3"></i>
                <h3 class="h5 fw-bold">Logistique Express</h3>
                <p class="text-muted">Partenariat avec les meilleurs transporteurs pour une livraison en 24/48h avec suivi en temps réel.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm border-0 rounded-4 text-center">
                <i class="bi bi-headset fs-1 text-primary mb-3"></i>
                <h3 class="h5 fw-bold">Support 24/7</h3>
                <p class="text-muted">Une équipe dédiée pour répondre à vos questions techniques ou logistiques à tout moment.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}