{% extends 'base.html.twig' %}

{% block title %}Nos Tarifs & Avantages | ShoppingFree{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Choisissez votre expérience</h1>
        <p class="lead text-muted">Des avantages exclusifs pour nos clients fidèles.</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-transparent border-0 pt-4 text-center">
                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3">Basique</span>
                    <h3 class="mt-2 fw-bold">Standard</h3>
                </div>
                <div class="card-body text-center px-4">
                    <div class="my-3">
                        <span class="display-4 fw-bold">0€</span>
                        <span class="text-muted">/mois</span>
                    </div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-3"><i class="bi bi-check2-circle text-primary me-2"></i> Accès à toute la boutique</li>
                        <li class="mb-3"><i class="bi bi-check2-circle text-primary me-2"></i> Paiement sécurisé Stripe</li>
                        <li class="mb-3 text-muted"><i class="bi bi-x-circle me-2"></i> Livraison Prioritaire</li>
                        <li class="mb-3 text-muted"><i class="bi bi-x-circle me-2"></i> Support Client dédié</li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 px-4">
                    <a href="{{ path('app_register') }}" class="btn btn-outline-primary w-100 rounded-pill fw-bold">S'inscrire gratuitement</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-lg border-primary border-2 rounded-4 overflow-hidden" style="transform: scale(1.05);">
                <div class="card-header bg-primary text-white text-center py-3">
                    <span class="badge bg-white text-primary rounded-pill px-3">RECOMMANDÉ</span>
                    <h3 class="mt-2 fw-bold mb-0 text-white">Premium SF</h3>
                </div>
                <div class="card-body text-center px-4">
                    <div class="my-3">
                        <span class="display-4 fw-bold">9,99€</span>
                        <span class="text-muted">/mois</span>
                    </div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-3"><i class="bi bi-patch-check-fill text-primary me-2"></i> <strong>Livraison Express 24h</strong></li>
                        <li class="mb-3"><i class="bi bi-patch-check-fill text-primary me-2"></i> Retours illimités gratuits</li>
                        <li class="mb-3"><i class="bi bi-patch-check-fill text-primary me-2"></i> Support VIP Prioritaire</li>
                        <li class="mb-3"><i class="bi bi-patch-check-fill text-primary me-2"></i> Accès aux ventes privées</li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 px-4">
                    <button class="btn btn-primary w-100 rounded-pill fw-bold shadow">Essai gratuit de 30 jours</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-5 text-center">
        <h4 class="fw-bold">Besoin d'aide ?</h4>
        <p class="text-muted">Consultez notre page <a href="{{ path('app_resources') }}" class="text-primary text-decoration-none">Ressources & FAQ</a></p>
    </div>
</div>
{% endblock %}