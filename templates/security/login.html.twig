{% extends 'base.html.twig' %}

{% block title %}Connexion - OttoEtKhol{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-lg p-4 mt-5 border-0" style="border-radius: 15px;">
            <form method="post">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-3">
                        Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Déconnexion</a>
                    </div>
                {% endif %}

                <h1 class="text-center mb-4 fw-bold text-dark">Connexion</h1>
                
                <div class="mb-3">
                    <label for="inputEmail" class="form-label">Email</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus placeholder="votre@email.fr">
                </div>

                <div class="mb-3">
                    <label for="inputPassword" class="form-label">Mot de passe</label>
                    <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# La case "Se souvenir de moi" que vous avez activée en mode "Always" ou "Checkbox" #}
                <div class="checkbox mb-4">
                    <label>
                        <input type="checkbox" name="_remember_me" checked> Se souvenir de moi
                    </label>
                </div>

                <button class="btn btn-primary btn-lg w-100 fw-bold border border-dark border-3 shadow-sm" type="submit">
                     SE CONNECTER
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted">Pas encore de compte ? <a href="{{ path('app_register') }}" class="text-decoration-none">S'inscrire ici</a></small>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-primary {
        background-color: #0d6efd;
        transition: all 0.2s ease-in-out;
    }
    .btn-primary:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2) !important;
        filter: brightness(1.1);
    }
</style>
{% endblock %}