<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ShoppingFree | Boutique Officielle{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --nav-bg: #000000;
            --sf-primary: #3b82f6;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar Style Pro */
        .navbar { 
            background-color: var(--nav-bg) !important;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .navbar-brand { font-weight: 800; font-size: 1.5rem; letter-spacing: -1px; }
        .nav-link { font-weight: 600; color: rgba(255,255,255,0.8) !important; font-size: 0.95rem; }
        .nav-link:hover { color: #fff !important; }

        /* Bouton Dark Mode (Lune) */
        #themeToggle {
            background: rgba(255,255,255,0.1);
            border: none;
            color: #fff;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s;
        }
        #themeToggle:hover { background: rgba(255,255,255,0.2); transform: scale(1.1); }

        /* Badge Panier */
        .badge-cart { font-size: 0.6rem; border: 2px solid #000; }

        /* Dropdown Style */
        .dropdown-menu { border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.2); border-radius: 15px; padding: 10px; }
        .dropdown-item { border-radius: 8px; padding: 10px 15px; font-weight: 500; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-lg">
        <div class="container">
            <a class="navbar-brand text-white d-flex align-items-center" href="{{ path('app_home') }}">
                <i class="bi bi-bag-heart-fill text-primary me-2"></i> <span class="d-none d-sm-inline">ShoppingFree</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sfNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="sfNav">
                <ul class="navbar-nav me-auto ps-lg-4">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">
                            <i class="bi bi-shop me-1"></i> Boutique
                        </a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_solutions') }}">Solutions</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_pricing') }}">Prix</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_resources') }}">Ressources</a></li>
                </ul>

                <div class="d-flex align-items-center">
                    <button id="themeToggle" class="me-3">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>

                    <a href="{{ path('app_cart') }}" class="nav-link position-relative me-3">
                        <i class="bi bi-cart3 fs-5 text-white"></i>
                        {% if app.session.get('panier')|length > 0 %}
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary badge-cart">
                                {{ app.session.get('panier')|length }}
                            </span>
                        {% endif %}
                    </a>

                    {% if app.user %}
                        {# LE MENU DÉROULANT UTILISATEUR #}
                        <div class="dropdown">
                            <button class="btn btn-outline-light dropdown-toggle rounded-pill px-4 fw-bold" type="button" data-bs-toggle="dropdown">
                                {{ app.user.userIdentifier|slice(0, 10) }}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="{{ path('app_account_orders') }}"><i class="bi bi-list-check me-2"></i> Mes Commandes</a></li>
                                
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-primary" href="{{ path('app_admin_dashboard') }}"><i class="bi bi-cpu me-2"></i> Administration</a></li>
                                {% endif %}
                                
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i> Déconnexion</a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="nav-link me-3">Se connecter</a>
                        <a href="{{ path('app_register') }}" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">S'inscrire gratuitement</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="mt-auto pt-5 pb-3" style="background-color: #0a0a0a; color: rgba(255,255,255,0.7);">
        <div class="container">
            <div class="row g-5 mb-4">

                {# Colonne marque #}
                <div class="col-lg-4">
                    <a href="{{ path('app_home') }}" class="text-white text-decoration-none d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-bag-heart-fill text-primary fs-4"></i>
                        <span class="fw-bold fs-5">ShoppingFree</span>
                    </a>
                    <p class="small" style="line-height: 1.8;">
                        Votre boutique tech de confiance. Les meilleurs produits high-tech aux meilleurs prix, livrés rapidement partout en France.
                    </p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-white opacity-75 hover-opacity-100"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" class="text-white opacity-75"><i class="bi bi-twitter-x fs-5"></i></a>
                        <a href="#" class="text-white opacity-75"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-white opacity-75"><i class="bi bi-youtube fs-5"></i></a>
                    </div>
                </div>

                {# Colonne boutique #}
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: .08em; font-size: 0.8rem;">Boutique</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="{{ path('app_home') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Tous les produits</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Smartphones</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Ordinateurs</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Consoles</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Audio</a></li>
                    </ul>
                </div>

                {# Colonne compte #}
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: .08em; font-size: 0.8rem;">Mon compte</h6>
                    <ul class="list-unstyled small">
                        {% if app.user %}
                            <li class="mb-2"><a href="{{ path('app_account_orders') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Mes commandes</a></li>
                            <li class="mb-2"><a href="{{ path('app_cart') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Mon panier</a></li>
                            <li class="mb-2"><a href="{{ path('app_logout') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Déconnexion</a></li>
                        {% else %}
                            <li class="mb-2"><a href="{{ path('app_login') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Se connecter</a></li>
                            <li class="mb-2"><a href="{{ path('app_register') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Créer un compte</a></li>
                            <li class="mb-2"><a href="{{ path('app_cart') }}" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Mon panier</a></li>
                        {% endif %}
                    </ul>
                </div>

                {# Colonne aide #}
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: .08em; font-size: 0.8rem;">Aide</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">FAQ</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Livraison</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Retours</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: rgba(255,255,255,0.6);">Contact</a></li>
                    </ul>
                </div>

                {# Colonne paiement #}
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing: .08em; font-size: 0.8rem;">Paiement sécurisé</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-white text-dark px-2 py-2"><i class="bi bi-credit-card me-1"></i>Visa</span>
                        <span class="badge bg-white text-dark px-2 py-2"><i class="bi bi-credit-card me-1"></i>Mastercard</span>
                        <span class="badge bg-white text-dark px-2 py-2"><i class="bi bi-stripe me-1"></i>Stripe</span>
                        <span class="badge bg-white text-dark px-2 py-2"><i class="bi bi-paypal me-1"></i>PayPal</span>
                    </div>
                    <p class="small mt-3" style="color: rgba(255,255,255,0.5);">
                        <i class="bi bi-shield-lock me-1 text-success"></i> Paiements 100% sécurisés SSL
                    </p>
                </div>

            </div>

            <hr style="border-color: rgba(255,255,255,0.1);">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <p class="small mb-0" style="color: rgba(255,255,255,0.4);">
                    &copy; {{ "now"|date("Y") }} ShoppingFree. Tous droits réservés.
                </p>
                <div class="d-flex gap-3">
                    <a href="#" class="small text-decoration-none" style="color: rgba(255,255,255,0.4);">Mentions légales</a>
                    <a href="#" class="small text-decoration-none" style="color: rgba(255,255,255,0.4);">CGV</a>
                    <a href="#" class="small text-decoration-none" style="color: rgba(255,255,255,0.4);">Confidentialité</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;
        const icon = themeToggle.querySelector('i');

        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);

        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            applyTheme(newTheme);
        });

        function applyTheme(theme) {
            html.setAttribute('data-bs-theme', theme);
            localStorage.setItem('theme', theme);
            icon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
            icon.style.color = theme === 'dark' ? '#ffcc00' : '#fff';
        }
    </script>
</body>
</html>