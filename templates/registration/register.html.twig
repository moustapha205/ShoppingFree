{% extends 'base.html.twig' %}

{% block title %}S'inscrire - OttoEtKhol{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg p-4 mt-5 border-0" style="border-radius: 15px;">
            <h1 class="text-center mb-4 fw-bold text-dark">Inscription Élève</h1>

            {{ form_start(registrationForm) }}
                <div class="mb-3">
                    {{ form_row(registrationForm.email, {
                        'label': 'Votre Email',
                        'attr': {'class': 'form-control', 'placeholder': 'exemple@otto.fr'}
                    }) }}
                </div>
                
                <div class="mb-3">
                    {{ form_row(registrationForm.plainPassword, {
                        'label': 'Créer un mot de passe',
                        'attr': {'class': 'form-control'}
                    }) }}
                </div>

                {# Bloc pour les conditions d'utilisation déjà existantes dans votre projet #}
                <div class="mb-4 p-3 bg-light rounded border">
                    <div class="form-check d-flex align-items-center">
                        {{ form_widget(registrationForm.agreeTerms, {
                            'attr': {'class': 'form-check-input'}
                        }) }}
                        <label class="form-check-label ms-2" for="{{ registrationForm.agreeTerms.vars.id }}">
                            J'accepte les <a href="#" class="text-primary fw-bold">conditions d'utilisation</a>
                        </label>
                    </div>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                {# Le bouton bleu "Primary" avec la bordure noire demandée #}
                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold border border-dark border-3 shadow-sm">
                     S'INSCRIRE MAINTENANT
                </button>
            {{ form_end(registrationForm) }}
            
            <div class="text-center mt-3">
                <small class="text-muted">Déjà membre ? <a href="{{ path('app_login') }}" class="text-decoration-none">Se connecter</a></small>
            </div>
        </div>
    </div>
</div>

<style>
    /* Style pour harmoniser le bouton bleu avec votre Navbar */
    .btn-primary {
        background-color: #0d6efd;
        transition: all 0.2s ease-in-out;
    }
    .btn-primary:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2) !important;
        filter: brightness(1.1);
    }
</style>
{% endblock %}