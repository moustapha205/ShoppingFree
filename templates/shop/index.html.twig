{% extends 'base.html.twig' %}

{% block title %}ShoppingFree | Boutique{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-5 text-center fw-bold">Nos Produits Tech</h1>

    <div class="row row-cols-1 row-cols-md-4 g-4 text-start">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">

                    {% if product.image %}
                        <img src="{{ asset(product.image) }}" class="card-img-top" alt="{{ product.name }}" style="height: 180px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light" style="height: 180px;">
                            <i class="bi bi-box-seam text-secondary" style="font-size: 3rem;"></i>
                        </div>
                    {% endif %}

                    <div class="card-body text-center">
                        {% if product.category %}
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1 mb-1 small">{{ product.category }}</span>
                        {% endif %}

                        <h5 class="card-title fw-bold mt-1">{{ product.name }}</h5>
                        <p class="text-muted small">Réf : {{ product.sku }}</p>
                        <h4 class="text-primary fw-bold">{{ product.priceHt }} €</h4>

                        <div class="d-flex gap-2 mt-2">
                            <a href="{{ path('app_boutique_show', {'id': product.id}) }}" class="btn btn-outline-primary flex-fill rounded-pill fw-bold">
                                <i class="bi bi-eye me-1"></i> Détail
                            </a>
                            <form action="{{ path('cart_add', {'id': product.id}) }}" method="post" class="flex-fill">
                                <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">
                                    <i class="bi bi-cart-plus me-1"></i> Panier
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
